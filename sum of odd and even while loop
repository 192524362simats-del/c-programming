#include <stdio.h>

int main() {
    int i = 1, n;
    int even_sum = 0, odd_sum = 0;

    printf("Enter the limit: ");
    scanf("%d", &n);

    while(i <= n) {
        if(i % 2 == 0) {
            even_sum += i;
        } else {
            odd_sum += i;
        }
        i++;
    }

    printf("Sum of even numbers = %d\n", even_sum);
    printf("Sum of odd numbers = %d\n", odd_sum);

    return 0;
}
