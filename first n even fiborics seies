#include <stdio.h>

int main() {
    int n, count = 0;
    int a = 0, b = 1, c;

    printf("Enter number of even Fibonacci terms: ");
    scanf("%d", &n);

    printf("Even Fibonacci Series: ");

    while(count < n) {
        if(a % 2 == 0) {
            printf("%d ", a);
            count++;
        }
        c = a + b;
        a = b;
        b = c;
    }

    return 0;
}
